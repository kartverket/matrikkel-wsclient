<?xml version="1.0" encoding="ISO-8859-1"?>
<xs:schema
        xmlns:sakns="http://kartverket.no/grunnbok/wsapi/v2/domain/saksbehandling"
        xmlns:basistyperns="http://kartverket.no/grunnbok/wsapi/v2/domain/basistyper"
        xmlns:meldingns="http://kartverket.no/grunnbok/wsapi/v2/domain/melding"
        xmlns:grunnboksidenterns="http://kartverket.no/grunnbok/wsapi/v2/domain/grunnboksidenter"
        xmlns:register_dokumentns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/dokument"
        xmlns:register_rettsstiftelsens="http://kartverket.no/grunnbok/wsapi/v2/domain/register/rettsstiftelse"
        xmlns:register_heftelsens="http://kartverket.no/grunnbok/wsapi/v2/domain/register/rettsstiftelse/heftelse"
        xmlns:register_registerenhetns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/registerenhet"
        xmlns:register_koderns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/koder"
        xmlns:register_adressens="http://kartverket.no/grunnbok/wsapi/v2/domain/register/adresse"
        xmlns:register_personns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/person"
        xmlns:register_saksinfons="http://kartverket.no/grunnbok/wsapi/v2/domain/register/saksinformasjon"
        xmlns:register_brukerns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/bruker"
        xmlns:register_registreringns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/registrering"
        xmlns:integrasjon_matrikkelen="http://kartverket.no/grunnbok/wsapi/v2/service/matrikkelen"
        xmlns:saksbehandlingns="http://kartverket.no/grunnbok/wsapi/v2/domain/saksbehandling"
        xmlns:xs="http://www.w3.org/2001/XMLSchema"
        version="1.0"
        targetNamespace="http://kartverket.no/grunnbok/wsapi/v2/domain/saksbehandling"
        elementFormDefault="qualified">

    <xs:import schemaLocation="basistyper.xsd" namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/basistyper"/>
    <xs:import schemaLocation="grunnboksidenter.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/grunnboksidenter"/>

    <xs:import schemaLocation="register_dokument.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/dokument"/>
    <xs:import schemaLocation="register_rettsstiftelse.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/rettsstiftelse"/>
    <xs:import schemaLocation="register_rettsstiftelse_heftelse.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/rettsstiftelse/heftelse"/>
    <xs:import schemaLocation="register_adresse.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/adresse"/>
    <xs:import schemaLocation="register_person.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/person"/>

    <xs:import schemaLocation="servicetyper_matrikkelen.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/service/matrikkelen"/>
    <xs:import schemaLocation="register_registerenhet.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/registerenhet"/>

    <xs:import schemaLocation="register_koder.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/koder"/>

    <xs:import schemaLocation="register_saksinformasjon.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/saksinformasjon"/>
    <xs:import schemaLocation="register_bruker.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/bruker"/>
    <xs:import schemaLocation="register_registrering.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/registrering"/>

    <xs:import schemaLocation="melding.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/melding"/>

    <!-- Sak -->

    <xs:complexType name="SakId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistoryId">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="RettesakId">
        <xs:complexContent>
            <xs:extension base="sakns:SakId">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="RettesakIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:RettesakId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SakIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:SakId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="Sak">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="saksinformasjonId" type="register_saksinfons:SaksinformasjonId"/>
                    <xs:element name="saksbehandlerId" type="register_brukerns:BrukerId"/>
                    <xs:element name="mappeeierId" type="register_brukerns:BrukerId"/>
                    <xs:element name="createdAt" type="basistyperns:LocalDateTime"/>
                    <xs:element name="innkommendeKanal">
                        <xs:simpleType>
                            <xs:restriction base="sakns:InnkommendeKanal"/>
                        </xs:simpleType>
                    </xs:element>
                    <xs:element name="meldingId" type="meldingns:MeldingId"/>
                    <xs:element name="kontrollresultaterFraSaksbehandler"
                                type="meldingns:Kontrollresultater"/>
                    <xs:element name="kontrollresultaterFraSisteEvaluering"
                                type="meldingns:Kontrollresultater"/>
                    <xs:element name="svarbrevId" type="sakns:SvarbrevId"/>
                    <xs:element name="foreloepigRegistreringId"
                                type="register_registreringns:ForeloepigRegistreringId"/>
                    <xs:element name="saksloggId" type="sakns:SaksloggId"/>
                    <xs:element name="registerenheterForSak" type="sakns:RegisterenheterForSakList"/>
                    <xs:element name="maalformId" type="register_koderns:MaalformKodeId"/>
                    <xs:element name="saksinnholdId" type="register_koderns:SaksinnholdKodeId"/>
                    <xs:element name="saksbehandlingsenhetId" type="register_koderns:SaksbehandlingsenhetKodeId"/>
                    <xs:element name="behandlingsnivaaId" type="register_koderns:BehandlingsnivaaKodeId"/>
                    <xs:element name="notat" type="xs:string"/>
                    <xs:element name="saksreferanser" type="sakns:SaksreferanseList"/>
                    <xs:element name="returtypeKodeId" type="register_koderns:ReturtypeKodeId"/>
                    <xs:element name="arkenDokumentId" type="xs:string"/>
                    <xs:element name="lokalFilstiArkenDokument" type="xs:string"/>
                    <xs:element name="opprettetArkenDokumentFraElida" type="xs:boolean" nillable="true"/>
                    <xs:element name="oenskerIkkeGrunnboksutskrift" type="xs:boolean" nillable="true"/>
                    <xs:element name="genereresIkkeGrunnboksutskrift" type="xs:boolean" nillable="true"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Rettesak">
        <xs:complexContent>
            <xs:extension base="sakns:Sak">
                <xs:sequence>
                    <xs:element name="aarsakTilRettingIds" type="register_koderns:AarsakTilRettingKodeIdList"/>
                    <xs:element name="dokumenterIds" type="register_dokumentns:DokumentIdList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SaksreferanseList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:Saksreferanse"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="Saksreferanse">
        <xs:complexContent>
            <xs:extension base="basistyperns:EntityComponentWithHistory">
                <xs:sequence>
                    <xs:element name="saksreferanse" type="xs:string"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="RegisterenheterForSakList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:RegisterenhetForSak"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RegisterenhetForSak">
        <xs:complexContent>
            <xs:extension base="basistyperns:EntityComponentWithHistory">
                <xs:sequence/>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="MatrikkelenhetForSak">
        <xs:complexContent>
            <xs:extension base="sakns:RegisterenhetForSak">
                <xs:sequence>
                    <xs:sequence>
                        <xs:element name="registerenhetIdent" type="grunnboksidenterns:MatrikkelenhetIdent"/>
                    </xs:sequence>

                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="BorettslagsandelForSak">
        <xs:complexContent>
            <xs:extension base="sakns:RegisterenhetForSak">
                <xs:sequence>
                    <xs:sequence>
                        <xs:element name="registerenhetIdent" type="grunnboksidenterns:BorettslagsandelIdent"/>
                    </xs:sequence>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:simpleType name="InnkommendeKanal">
        <xs:restriction base="xs:string">
            <xs:enumeration value="ALTINN"/>
            <xs:enumeration value="WEBSERVICES"/>
            <xs:enumeration value="SAKSKLIENT_ELEKTRONISK"/>
            <xs:enumeration value="SAKSKLIENT"/>
            <xs:enumeration value="KONVERTERT"/>
            <!-- Usikker på om denne hører hjemme her, høres ut som en intern greie -->
        </xs:restriction>
    </xs:simpleType>

    <xs:complexType name="InnkommendeKanalList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item">
                <xs:simpleType>
                    <xs:restriction base="sakns:InnkommendeKanal"/>
                </xs:simpleType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="GrunnboksutskriftId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistoryId">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="GrunnboksutskriftIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:GrunnboksutskriftId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="Grunnboksutskrift">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="gjelderRegisterenhetId" type="register_registerenhetns:RegisterenhetId"/>
                    <xs:element name="sakId" type="sakns:SakId"/>
                    <xs:element name="pdfUtskrift" type="xs:base64Binary"/>
                    <xs:element name="signertUtskrift" type="xs:base64Binary"/>
                    <xs:element name="linkTilPdfUtskrift" type="xs:string" nillable="true"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="GrunnboksutskriftList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:Grunnboksutskrift"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="KraftledningsbladId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistoryId">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="KraftledningsbladIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:KraftledningsbladId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="Kraftledningsblad">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="sakId" type="sakns:SakId"/>
                    <xs:element name="gjelderKraftledningId" type="register_heftelsens:KraftledningId"/>
                    <xs:element name="blad" type="xs:base64Binary"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="KraftledningsbladList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:Kraftledningsblad"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="GrunnboksutskriftIdMedRegisterenhetId">
        <xs:sequence>
            <xs:element name="grunnboksutskriftId" type="sakns:GrunnboksutskriftId"/>
            <xs:element name="registerenhetId" type="register_registerenhetns:RegisterenhetId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="GrunnboksutskriftIdMedRegisterenhetIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="sakns:GrunnboksutskriftIdMedRegisterenhetId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FindSakParameters">
        <xs:sequence>
            <xs:element name="sakIds" type="basistyperns:LongList"/>
            <xs:element name="fraOgMedDato" type="basistyperns:LocalDate"/>
            <xs:element name="tilOgMedDato" type="basistyperns:LocalDate"/>
            <xs:element name="saksstatuser" type="register_saksinfons:SaksstatusList"/>
            <xs:element name="behandlingsstatuser" type="register_registreringns:BehandlingsstatusList"/>
            <xs:element name="behandlingsutfall" type="register_saksinfons:BehandlingsutfallList"/>
            <xs:element name="fraDokumentaar" type="xs:int" nillable="true"/>
            <xs:element name="tilDokumentaar" type="xs:int" nillable="true"/>
            <xs:element name="fraDokumentnummer" type="xs:long" nillable="true"/>
            <xs:element name="tilDokumentnummer" type="xs:long" nillable="true"/>
            <xs:element name="brukernavn" type="basistyperns:StringList"/>
            <xs:element name="sakType" type="xs:string"/>
            <xs:element name="saksnummerFra" type="xs:long" nillable="true"/>
            <xs:element name="saksnummerTil" type="xs:long" nillable="true"/>
            <xs:element name="sortertRetning" type="xs:string"/>
            <xs:element name="innkommendeKanal" type="sakns:InnkommendeKanalList"/>
            <xs:element name="limit" type="xs:int"/>
            <xs:element name="registerenhetIdenter" type="grunnboksidenterns:RegisterenhetIdentList"/>
            <xs:element name="sakspersonIdentifikasjonsnumre" type="sakns:IdentifikasjonsnummerList"/>
            <xs:element name="saksbehandlingsenheter" type="register_koderns:SaksbehandlingsenhetKodeIdList"/>
            <xs:element name="behandlingsnivaaer" type="register_koderns:BehandlingsnivaaKodeIdList"/>
            <xs:element name="skrevetUt" type="xs:boolean" nillable="true"/>
        </xs:sequence>
    </xs:complexType>

    <xs:simpleType name="HentSakPaa" final="restriction">
        <xs:restriction base="xs:string">
            <xs:enumeration value="SAKSNUMMER"/>
            <xs:enumeration value="DOKUMENTNUMMER"/>
        </xs:restriction>
    </xs:simpleType>

    <xs:complexType name="HentSakParameters">
        <xs:sequence>
            <xs:element name="dokumentaar" type="xs:int"/>
            <xs:element name="nummer" type="xs:long"/>
            <xs:element name="embeteKode" type="register_koderns:EmbeteKode"/>
            <xs:element name="hentSakPaa" type="sakns:HentSakPaa"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="IdentifikasjonsnummerList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SaksloggIdTilSaksloggEntryIdsMap">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="entry">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="key" type="sakns:SaksloggId"/>
                        <xs:element name="value" type="sakns:SaksloggEntryIdList"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SaksinformasjonIdToSakIdMap">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="entry">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="key" type="register_saksinfons:SaksinformasjonId"/>
                        <xs:element name="value" type="sakns:SakId"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>


    <xs:complexType name="MeldingIdToSakIdMap">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="entry">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="key" type="meldingns:MeldingId"/>
                        <xs:element name="value" type="sakns:SakId"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SaksinformasjonIdToLocalDateTimeMap">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="entry">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="key" type="register_saksinfons:SaksinformasjonId"/>
                        <xs:element name="value" type="basistyperns:LocalDateTime"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="ForeloepigRegistreringIdToSakIdMap">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="entry">
                <xs:complexType>
                    <xs:sequence>
                        <xs:element name="key" type="register_registreringns:ForeloepigRegistreringId"/>
                        <xs:element name="value" type="sakns:SakId"/>
                    </xs:sequence>
                </xs:complexType>
            </xs:element>
        </xs:sequence>
    </xs:complexType>


    <xs:complexType name="SaksloggId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistoryId">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Sakslogg">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="saksloggEntryIds" type="sakns:SaksloggEntryIdList"/>
                    <xs:element name="sakId" type="sakns:SakId"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SaksloggEntryId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistoryId">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SaksloggEntryIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:SaksloggEntryId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SaksloggIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:SaksloggId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SaksloggEntry">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="tidsstempel" type="basistyperns:Timestamp"/>
                    <xs:element name="brukerId" type="register_brukerns:BrukerId"/>
                    <xs:element name="saksstatus">
                        <xs:simpleType>
                            <xs:restriction base="register_saksinfons:Saksstatus"/>
                        </xs:simpleType>
                    </xs:element>
                    <xs:element name="behandlingsutfall">
                        <xs:simpleType>
                            <xs:restriction base="register_saksinfons:Behandlingsutfall"/>
                        </xs:simpleType>
                    </xs:element>
                    <xs:element name="behandlingsstatus">
                        <xs:simpleType>
                            <xs:restriction base="register_registreringns:Behandlingsstatus"/>
                        </xs:simpleType>
                    </xs:element>
                    <xs:element name="foreslaattBehandlingsutfall">
                        <xs:simpleType>
                            <xs:restriction base="register_registreringns:ForeslaattBehandlingsutfall"/>
                        </xs:simpleType>
                    </xs:element>
                    <xs:element name="saksloggId" type="sakns:SaksloggId"/>
                    <xs:element name="tekst" type="xs:string"/>
                    <xs:element name="saksbehandlingsenhetId" type="register_koderns:SaksbehandlingsenhetKodeId"/>
                    <xs:element name="behandlingsnivaaId" type="register_koderns:BehandlingsnivaaKodeId"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SvarbrevId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistoryId">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SvarbrevIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:SvarbrevId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="Svarbrev">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="sakId" type="sakns:SakId"/>
                    <xs:element name="brevinnhold" type="sakns:Brevinnhold"/>
                    <xs:element name="oppdateringsBruker" type="xs:string" nillable="true"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Brevinnhold">
        <xs:sequence>
            <xs:element name="htmlContent" type="xs:base64Binary"/>
            <xs:element name="printed" type="xs:boolean"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InformasjonFraMatrikkelenForMatrikkelenhet">
        <xs:sequence>
            <xs:element name="informasjonselementer" type="sakns:InformasjonOmMatrikkelenhetList"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InformasjonOmMatrikkelenhetList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="sakns:InformasjonOmMatrikkelenhet"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="InformasjonOmMatrikkelenhet">
        <xs:sequence>
            <xs:element name="matrikkelenhetIdent" type="grunnboksidenterns:MatrikkelenhetIdent"/>
