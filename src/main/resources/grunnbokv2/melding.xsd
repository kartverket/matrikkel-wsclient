<?xml version="1.0" encoding="ISO-8859-1"?>

<xs:schema version="1.0"
           targetNamespace="http://kartverket.no/grunnbok/wsapi/v2/domain/melding"
           xmlns:meldingns="http://kartverket.no/grunnbok/wsapi/v2/domain/melding"

           xmlns:basistyperns="http://kartverket.no/grunnbok/wsapi/v2/domain/basistyper"
           xmlns:kodelistens="http://kartverket.no/grunnbok/wsapi/v2/domain/kodeliste"
           xmlns:grunnboksidenterns="http://kartverket.no/grunnbok/wsapi/v2/domain/grunnboksidenter"

           xmlns:register_rettsstiftelsens="http://kartverket.no/grunnbok/wsapi/v2/domain/register/rettsstiftelse"
           xmlns:register_registerenhetns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/registerenhet"
           xmlns:register_personns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/person"
           xmlns:register_koderns="http://kartverket.no/grunnbok/wsapi/v2/domain/register/koder"

           xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">

    <xs:import schemaLocation="basistyper.xsd" namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/basistyper"/>
    <xs:import schemaLocation="kodeliste.xsd" namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/kodeliste"/>

    <xs:import schemaLocation="grunnboksidenter.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/grunnboksidenter"/>

    <xs:import schemaLocation="register_rettsstiftelse.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/rettsstiftelse"/>
    <xs:import schemaLocation="register_registerenhet.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/registerenhet"/>
    <xs:import schemaLocation="register_person.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/person"/>
    <xs:import schemaLocation="register_koder.xsd"
               namespace="http://kartverket.no/grunnbok/wsapi/v2/domain/register/koder"/>

    <!-- Melding -->

    <xs:complexType name="MeldingId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokBubbleObjectId"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="MeldingIdList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item" type="meldingns:MeldingId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="Melding">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="registreringstidspunkt" type="basistyperns:Timestamp"/>
                    <xs:element name="innsendingId" type="xs:long" minOccurs="0" maxOccurs="1"/>
                    <xs:element name="forsendelsesreferanse" type="xs:string"/>
                    <xs:element name="rekkefoelgenummer" type="xs:int"/>
                    <xs:element name="meldingSpecification" type="meldingns:MeldingSpecification"/>
                    <xs:element name="formidletAvId" type="meldingns:FormidlerId"/>
                    <xs:element name="elektroniskeSignaturer"
                                type="meldingns:ElektroniskeSignaturerList"/>
                    <xs:element name="dokumentreferanser"
                                type="meldingns:MeldingDokumentreferanseList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="FormidlerId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokBubbleObjectId"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="TinglysingBrukerId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokBubbleObjectId"/>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="Formidler">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="personIdent" type="grunnboksidenterns:PersonIdent"/>
                    <xs:element name="kanTinglyseUsignertMelding" type="xs:boolean"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="TinglysingBruker">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="brukernavn" type="xs:string"/>
                    <xs:element name="formidlerId" type="meldingns:FormidlerId"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>


    <xs:complexType name="RettsstiftelsestypebegrensningId">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokBubbleObjectId"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="Rettsstiftelsestypebegrensning">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokObjectWithHistory">
                <xs:sequence>
                    <xs:element name="rettsstiftelsestypeId" type="register_koderns:RettsstiftelsestypeKodeId"/>
                    <xs:element name="personIdent" type="grunnboksidenterns:PersonIdent"/>
                    <xs:element name="begrensningKategori" type="meldingns:BegrensningKategori"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:simpleType name="BegrensningKategori">
        <xs:restriction base="xs:string">
            <xs:enumeration value="TINGLYSING"/>
            <xs:enumeration value="RETTSENDRING"/>
        </xs:restriction>
    </xs:simpleType>

    <!-- KodeSpecification -->

    <xs:complexType name="KodeSpecification">
        <xs:sequence>
            <xs:element name="kodeverdi" type="xs:string"/>
            <xs:element name="navn" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RettsstiftelsestypeKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="FormaalKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="TilleggsdeltypeKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="DokumentavgiftsaarsakKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="BoligtypeKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="BrukstypeKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="AarsaksparagrafKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="LandkodeKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="OmsetningstypeKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="AnketypeKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="AarsakGebyrfritakKodeSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:KodeSpecification"/>
        </xs:complexContent>
    </xs:complexType>

    <!-- MeldingSpecification -->

    <xs:complexType name="MeldingSpecification">
        <xs:sequence>
            <xs:element name="innkommetElektronisk" type="xs:boolean"/>
            <xs:element name="dokumenter" type="meldingns:DokumentSpecificationList"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RettingUnitOfWorkTransfer">
        <xs:complexContent>
            <xs:extension base="basistyperns:GrunnbokUnitOfWorkTransfer">
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="RettemeldingSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:MeldingSpecification">
                <xs:sequence>
                    <xs:element name="rettingUnitOfWorkTransfer"
                                type="meldingns:RettingUnitOfWorkTransfer"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <!-- DokumentSpecification -->

    <xs:complexType name="DokumentSpecification">
        <xs:sequence>
            <xs:element name="ref" type="xs:string"/>
            <xs:element name="innsendersRef" type="xs:string"/>
            <xs:element name="ident" type="grunnboksidenterns:DokumentIdent"/>
            <xs:element name="signaturer" type="meldingns:PersonSpecificationList"/>
            <xs:element name="rettsstiftelser" type="meldingns:RettsstiftelseOperationList"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RettedokumentSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:DokumentSpecification">
                <xs:sequence>
                    <xs:element name="registrertDato" type="basistyperns:LocalDate"/>
                    <xs:element name="registrertTidspunkt" type="basistyperns:LocalTime"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="DokumentSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:DokumentSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <!-- RettsstiftelseOperations og Specifications -->

    <xs:complexType name="RettsstiftelseOperation">
        <xs:sequence>
            <xs:element name="rettsstiftelsesnummer" type="xs:int"/>
            <xs:element name="rettsstiftelsestype"
                        type="meldingns:RettsstiftelsestypeKodeSpecification"/>
            <xs:element name="aarsakGebyrfritak" type="meldingns:AarsakGebyrfritakKodeSpecification"/>
            <xs:element name="harGebyr" type="xs:boolean" minOccurs="0" maxOccurs="1"/>
            <xs:element name="tekster" type="register_rettsstiftelsens:TekstList"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RettsstiftelseOperationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:RettsstiftelseOperation"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PersonSpecification">
        <xs:sequence>
            <xs:element name="personId" type="register_personns:PersonId"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PersonSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:PersonSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RegisterenhetSpecification">
    </xs:complexType>

    <xs:complexType name="RegisterenhetSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:RegisterenhetSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="MatrikkelenhetSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:RegisterenhetSpecification">
                <xs:sequence>
                    <xs:element name="matrikkelenhetIdent" type="grunnboksidenterns:MatrikkelenhetIdent"/>
                    <xs:element name="kommunenavn" type="xs:string"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="MatrikkelenhetSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:MatrikkelenhetSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="BorettslagsandelSpecification">
        <xs:complexContent>
            <xs:extension base="meldingns:RegisterenhetSpecification">
                <xs:sequence>
                    <xs:element name="borettslagsandelIdent" type="grunnboksidenterns:BorettslagsandelIdent"/>
                    <xs:element name="borettslagnavn" type="xs:string"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="BorettslagsandelSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:BorettslagsandelSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="BorettslagSpecification">
        <xs:sequence>
            <xs:element name="borettslagnummer" type="xs:string"/>
            <xs:element name="borettslagnavn" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RegisterenhetsrettSpecification">
        <xs:sequence>
            <xs:element name="registerenhet" type="meldingns:RegisterenhetSpecification"/>
            <xs:element name="registerenhetsrettstype" type="xs:string"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="RegisterenhetsrettSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:RegisterenhetsrettSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PrioritetsbestemmelseForDokumentnummerOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:RettsendringOperation">
                <xs:sequence>
                    <xs:element name="veketFor" type="grunnboksidenterns:RettsstiftelseIdentList"/>
                    <xs:element name="sidestiltMed" type="grunnboksidenterns:RettsstiftelseIdentList"/>
                    <xs:element name="medBeloep" type="register_rettsstiftelsens:BeloepList"/>
                    <xs:element name="forBeloep" type="register_rettsstiftelsens:BeloepList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="RegisterenhetsendringOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:RettsstiftelseOperation">
                <xs:sequence>
                    <xs:element name="omsetningSpecification" type="meldingns:OmsetningSpecification"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="OpphevingAvSeksjoneringOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:RegisterenhetsendringOperation">
                <xs:sequence>
                    <xs:element name="til" type="meldingns:MatrikkelenhetSpecificationList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SeksjoneringOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:RegisterenhetsendringOperation">
                <xs:sequence>
                    <xs:element name="fra" type="meldingns:MatrikkelenhetSpecificationList"/>
                    <xs:element name="nye" type="meldingns:SeksjonssameieandelSpecificationList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SeksjonssameieandelSpecification">
        <xs:sequence>
            <xs:element name="seksjon" type="meldingns:MatrikkelenhetSpecification"/>
            <xs:element name="teller" type="xs:long"/>
            <xs:element name="nevner" type="xs:long"/>
            <xs:element name="loepenummer" type="xs:int"/>
            <xs:element name="formaalKode" type="meldingns:FormaalKodeSpecification"/>
            <xs:element name="tilleggsdeltypeKode" type="meldingns:TilleggsdeltypeKodeSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SeksjonssameieandelSpecificationList">
        <xs:sequence>
            <xs:element name="item" minOccurs="0" maxOccurs="unbounded"
                        type="meldingns:SeksjonssameieandelSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SeksjonssameieendringOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:RegisterenhetsendringOperation">
                <xs:sequence>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="SeksjonssameieandelList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="register_registerenhetns:Seksjonssameieandel"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="ReseksjoneringOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:SeksjonssameieendringOperation">
                <xs:sequence>
                    <xs:element name="seksjonertMatrikkelenhet" type="grunnboksidenterns:MatrikkelenhetIdent"/>
                    <xs:element name="delingAvSeksjonerSpecifications"
                                type="meldingns:DelingAvSeksjonerSpecificationList"/>
                    <xs:element name="nyeSeksjonerFraFellesarealSpecifications"
                                type="meldingns:DelingAvSeksjonerSpecificationList"/>
                    <xs:element name="sammenslaaingAvSeksjonerSpecifications"
                                type="meldingns:SammenslaaingAvSeksjonerSpecificationList"/>
                    <xs:element name="fjerningAvSeksjonerSpecifications"
                                type="meldingns:FjerningAvSeksjonerSpecificationList"/>
                    <xs:element name="reseksjoneringUtenEndringerSpecifications"
                                type="meldingns:SeksjonssameieandelSpecificationList"/>
                    <xs:element name="resultatEksisterendeSeksjonssameieandeler"
                                type="meldingns:SeksjonssameieandelSpecificationList"/>
                    <xs:element name="eksisterendeSeksjonssameieandeler"
                                type="meldingns:SeksjonssameieandelSpecificationList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="FjerningAvSeksjonerSpecification">
        <xs:sequence>
            <xs:element name="fjernSeksjonssameieandelSpecifications"
                        type="meldingns:SeksjonssameieandelSpecificationList"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="FjerningAvSeksjonerSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:FjerningAvSeksjonerSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="DelingAvSeksjonerSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:DelingAvSeksjonerSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="DelingAvSeksjonerSpecification">
        <xs:sequence>
            <xs:element name="nyeSeksjoner" type="meldingns:SeksjonssameieandelSpecificationList"/>
            <xs:element name="delesFraSeksjonerMedBroek"
                        type="meldingns:SeksjonMedOppgittBroekSpecificationList"/>
            <xs:element name="delesFraFellesareal" type="xs:boolean"/>
            <xs:element name="oppgittBroekForFellesarealTeller" type="xs:long"/>
            <xs:element name="oppgittBroekForFellesarealNevner" type="xs:long"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SammenslaaingAvSeksjonerSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:SammenslaaingAvSeksjonerSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SammenslaaingAvSeksjonerSpecification">
        <xs:sequence>
            <xs:element name="utgaaendeSeksjoner" type="meldingns:SeksjonssameieandelSpecificationList"/>
            <xs:element name="bestaaendeSeksjonssameieandelSpecification"
                        type="meldingns:SeksjonssameieandelSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SeksjonMedOppgittBroekSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:SeksjonMedOppgittBroekSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SeksjonMedOppgittBroekSpecification">
        <xs:sequence>
            <xs:element name="seksjonssameieandelSpecification"
                        type="meldingns:SeksjonssameieandelSpecification"/>
            <xs:element name="teller" type="xs:long"/>
            <xs:element name="nevner" type="xs:long"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SeksjonssameieandelFraTilSpecification">

        <xs:sequence>
            <xs:element name="fra" type="meldingns:MatrikkelenhetSpecification"/>
            <xs:element name="til" type="meldingns:SeksjonssameieandelSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SeksjonssameieandelFraTilSpecificationList">
        <xs:sequence>
            <xs:element minOccurs="0" maxOccurs="unbounded" name="item"
                        type="meldingns:SeksjonssameieandelFraTilSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="SammenslaaingAvEierseksjonssameierOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:RegisterenhetsendringOperation">
                <xs:sequence>
                    <xs:element name="fra" type="meldingns:MatrikkelenhetSpecificationList"/>
                    <xs:element name="til" type="meldingns:MatrikkelenhetSpecificationList"/>
                    <xs:element name="utgaaendeOgBestaaendeSeksjonssameieandeler" type="meldingns:SeksjonssameieandelFraTilSpecificationList"/>
                    <xs:element name="omnummereringAvUnderliggende" type="meldingns:MatrikkelenhetFraTilSpecificationList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="MatrikkelenhetsendringOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:RegisterenhetsendringOperation">
                <xs:sequence>
                    <xs:element name="fra" type="meldingns:MatrikkelenhetSpecificationList"/>
                    <xs:element name="til" type="meldingns:MatrikkelenhetSpecificationList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="FradelingOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:MatrikkelenhetsendringOperation">
                <xs:sequence>
                    <xs:element name="registerenhetsrettsandelerForNy"
                                type="meldingns:RegisterenhetsrettAndelerSpecificationList"/>
                    <xs:element name="rekvirenterAvForretning" type="meldingns:PersonSpecificationList"/>
                    <xs:element name="heftelserSomIkkeSkalOverfoeres"
                                type="grunnboksidenterns:RettsstiftelseIdentList"/>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="RegistreringAvTidligereUregistrertGrunnOperation">
        <xs:complexContent>
            <xs:extension base="meldingns:MatrikkelenhetsendringOperation"/>
        </xs:complexContent>
    </xs:complexType>

    <xs:complexType name="MatrikkelenhetFraTilSpecification">
        <xs:sequence>
            <xs:element name="fra" type="meldingns:MatrikkelenhetSpecification"/>
            <xs:element name="til" type="meldingns:MatrikkelenhetSpecification"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="MatrikkelenhetFraTilSpecificationList">
        <xs:sequence>
            <xs:element name="item" minOccurs="0" maxOccurs="unbounded"
                        type="meldingns:MatrikkelenhetFraTilSpecification"/>
