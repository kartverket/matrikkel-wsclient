#!groovy
@Library('common@master') _

/*
 Multibranch Pipeline for Continuous integration (CI) prosess i Jenkins.
 Hver branch har denne innsjekket pĂĄ fast plassering: config/jenkins-integration/Jenkinsfile
*/

pipeline { //declarative pipeline syntax
    // agent defines where the pipeline will run.
    agent {
        label 'matrikkelen'
    }

    triggers {
        cron('H H * * 7') //hver sĂ¸ndag
    }


    tools {
        jdk 'Java 11 Latest'
    }
    environment {
        GRADLE_USER_HOME = "$WORKSPACE/.gradle" // Forhindre samtidighetsproblemer
        GRADLE_OPTS = '-Dorg.gradle.daemon=false' +
            " -Dmaven.repo.local=$WORKSPACE/.m2/repository" // Forhindre samtidighetsproblemer

       GRUNNBOK            = credentials('matirkkel-wsclient-grunnbok-mat')
       GRUNNBOK_TINGLYSING = credentials('matrikkel-wsclient-tinglysing')
       LANDBRUKSREGISTER   = credentials('matrikkel-wsclient-landbruksregister')

       SECRETES_FOR_TESTING = " -Dgrunnbok.mat.username=$GRUNNBOK_USR" +
                      " -Dgrunnbok.mat.password=$GRUNNBOK_PSW" +
                      " -Dgrunnbok.tinglysing.username=$GRUNNBOK_TINGLYSING_USR" +
                      " -Dgrunnbok.tinglysing.password=$GRUNNBOK_TINGLYSING_PSW" +
                      " -Dlandbruksregister.username=$LANDBRUKSREGISTER_USR" +
                      " -Dlandbruksregister.password=$LANDBRUKSREGISTER_PSW"
    }

    stages {
        stage('Prepare') {
            steps {
                sh "./gradlew clean assemble --refresh-dependencies --profile ${gradleOptions(this)}"
            }
        }
        stage('Integration test') {
            steps {
                sh "./gradlew testIntegration -DignoreFailures=true ${SECRETES_FOR_TESTING} ${gradleOptions(this)}"
            }
            post {
                always {
                    junit '**/build/test-results/testIntegration/*.xml'
                }
            }
        }
    }

    // The options directive is for configuration that applies to the whole job.
    options {

        // Vi Ă¸nsker ikke ĂĄ fylle opp jenkins master med logger og artefakter av gamle bygg
        buildDiscarder(logRotator(artifactDaysToKeepStr: '', artifactNumToKeepStr: '30', daysToKeepStr: '', numToKeepStr: '90'))

        // Skip stages once the build status has gone to UNSTABLE
        skipStagesAfterUnstable()

        // And we'd really like to be sure that this build doesn't hang forever, so
        // let's time it out after an hour.
        timeout(time: 60, unit: 'MINUTES')

        // Prepend all console output generated by the Pipeline run with the time at which the line was emitted
        timestamps()
    }

    post {
        fixed {
            pushBuildFeed()
        }
        unsuccessful {
            pushBuildFeed()
        }
    }
}


static def gradleOptions(script) {
    return [
            '--stacktrace'
    ].join(' ')
}
